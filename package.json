{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "assistant:validate": "node scripts/validate-assistant-knowledge.mjs",
        "assistant:validate:test": "node --test tests/node/assistant-knowledge-validator.test.mjs",
        "assistant:manuals": "node scripts/generate-assistant-manuals.mjs",
        "assistant:n8n-documents": "node scripts/build-n8n-assistant-documents.mjs",
        "assistant:n8n-workflows": "node scripts/build-n8n-assistant-workflows.mjs",
        "n8n:assistant:validate": "node scripts/validate-n8n-assistant-workflows.mjs",
        "n8n:assistant:validate:test": "node --test tests/node/n8n-assistant-workflows-validator.test.mjs tests/node/n8n-assistant-hardening.test.mjs tests/node/n8n-assistant-final-security.test.mjs",
        "test:e2e": "playwright test",
        "test:e2e:headed": "playwright test --headed",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:report": "playwright show-report"
    },
    "devDependencies": {
        "@playwright/test": "^1.61.1",
        "@tailwindcss/forms": "^0.5.2",
        "@tailwindcss/vite": "^4.0.0",
        "alpinejs": "^3.4.2",
        "autoprefixer": "^10.4.2",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^3.1",
        "postcss": "^8.4.31",
        "tailwindcss": "^3.1.0",
        "vite": "^8.0.0"
    }
}
